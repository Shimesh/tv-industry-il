{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": "..",
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts",
    "../src/lib/chat-v2/protocol.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
